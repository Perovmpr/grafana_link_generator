{
	"manifest_version": 3,
	"name": "Grafana Link Generator",
	"version": "1.0",
	"description": "Отслеживает AJAX-запросы и генерирует ссылки в Grafana.",
	"permissions": [
		"webRequest",
		"activeTab",
		"storage",
		"tabs"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon48.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"options_page": "options.html",
	"icons": {
		"16": "icons/icon48.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}